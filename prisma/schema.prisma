generator client {
  provider = "prisma-client-js"
  // "native" covers local development on any OS. The musl target is the
  // Alpine engine the Docker image needs — without it the container starts
  // and then fails on the first query with "Query engine library not found".
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

model User {
  id        String    @id @default(auto()) @map("_id") @db.ObjectId
  clerkId   String    @unique
  email     String    @unique
  role      Role      @default(BUYER)
  isActive  Boolean   @default(true)
  // Profile (username uniqueness enforced in the action layer — Mongo unique
  // on optional fields rejects multiple nulls).
  username  String?
  name      String?
  // Contact number for WhatsApp notifications not tied to a delivery address
  // (profile changes, seller application updates, account status).
  phone     String?
  imageUrl  String?
  birthday  DateTime?
  gender    String?
  // Seller's shop address snapshot (JSON incl. lat/lng), edited on /profile.
  shopAddressJson String?
  // Eshopbox pickup location code for this seller's warehouse. Falls back to
  // ESHOPBOX_PICKUP_LOCATION_CODE when unset.
  pickupLocationCode String?
  createdAt DateTime  @default(now())
}

model Address {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  userId    String   @db.ObjectId
  label     String
  fullName  String
  phone     String
  line1     String
  line2     String?
  city      String
  state     String
  pincode   String
  // Pinpoint coordinates captured via "use my location".
  latitude  Float?
  longitude Float?
  isActive  Boolean  @default(false)
  createdAt DateTime @default(now())
}

model Category {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  name        String
  subcategory String?
  imageUrl    String?
  isActive    Boolean  @default(true)
  createdBy   String   @db.ObjectId
  createdAt   DateTime @default(now())
}

model Follow {
  id         String   @id @default(auto()) @map("_id") @db.ObjectId
  followerId String   @db.ObjectId
  sellerId   String   @db.ObjectId
  createdAt  DateTime @default(now())

  @@unique([followerId, sellerId])
}

model SellerRequest {
  id         String          @id @default(auto()) @map("_id") @db.ObjectId
  userId     String          @unique @db.ObjectId
  brandName  String
  phone      String
  category   String
  about      String
  status     SellerReqStatus @default(PENDING)
  createdAt  DateTime        @default(now())
  reviewedAt DateTime?
  reviewedBy String?
}

enum SellerReqStatus {
  PENDING
  APPROVED
  REJECTED
}

model ScheduledStream {
  id           String   @id @default(auto()) @map("_id") @db.ObjectId
  sellerId     String   @db.ObjectId
  title        String
  scheduledFor DateTime
  thumbnailUrl String?
  productIds   String[] @db.ObjectId
  createdAt    DateTime @default(now())
}

enum Role {
  BUYER
  SELLER
  ADMIN
}

model Product {
  id             String  @id @default(auto()) @map("_id") @db.ObjectId
  sellerId       String  @db.ObjectId
  title          String
  priceInPaise   Int
  availableStock Int
  // Required for every new product; optional in the DB so listings created
  // before images were mandatory still load.
  imageUrl       String?
  // Parcel dimensions — Eshopbox requires all four to book a shipment.
  // Defaults cover a small apparel packet so legacy rows stay shippable.
  weightGrams    Int     @default(500)
  lengthCm       Int     @default(25)
  breadthCm      Int     @default(20)
  heightCm       Int     @default(5)
  streamId       String? @db.ObjectId
}

model Stream {
  id                String       @id @default(auto()) @map("_id") @db.ObjectId
  sellerId          String       @db.ObjectId
  livekitRoomName   String       @unique
  status            StreamStatus @default(LIVE)
  title             String?
  thumbnailUrl      String?
  categoryId        String?      @db.ObjectId
  featuredProductId String?      @db.ObjectId
  startedAt         DateTime     @default(now())
  endedAt           DateTime?
}

enum StreamStatus {
  LIVE
  ENDED
}

model Reservation {
  id        String    @id @default(auto()) @map("_id") @db.ObjectId
  productId String    @db.ObjectId
  userId    String    @db.ObjectId
  streamId  String    @db.ObjectId
  quantity  Int       @default(1)
  status    ResStatus @default(PENDING)
  expiresAt DateTime
  createdAt DateTime  @default(now())
}

enum ResStatus {
  PENDING
  CONFIRMED
  EXPIRED
  CANCELLED
}

model Order {
  id                String        @id @default(auto()) @map("_id") @db.ObjectId
  reservationId     String        @unique @db.ObjectId
  // Empty string for COD orders (no Razorpay order exists).
  razorpayOrderId   String
  razorpayPaymentId String?
  // Grand total actually charged, i.e. goods + deliveryFeeInPaise.
  amountInPaise     Int
  // COD carries a flat delivery charge; online orders are 0.
  deliveryFeeInPaise Int          @default(0)
  status            OrderStatus   @default(CREATED)
  paymentMethod     PaymentMethod @default(ONLINE)
  // Delivery address snapshot (JSON) captured at purchase time.
  addressJson       String?
  createdAt         DateTime      @default(now())
  // Fulfilment timestamps, set when the seller advances the order.
  shippedAt         DateTime?
  deliveredAt       DateTime?
}

enum OrderStatus {
  CREATED
  PAID
  FAILED
  PLACED
  SHIPPED
  DELIVERED
  // Courier exception states, driven by the Eshopbox tracking webhook.
  // RTO = return to origin (delivery failed, parcel coming back to seller).
  RTO
  CANCELLED
}

/// A parcel booked with Eshopbox for one order.
model Shipment {
  id       String @id @default(auto()) @map("_id") @db.ObjectId
  orderId  String @unique @db.ObjectId
  sellerId String @db.ObjectId

  /// The `shipmentId` we send to Eshopbox — our idempotency key with them.
  externalShipmentId String  @unique
  /// AWB / tracking number issued by the courier.
  trackingId         String?
  courierName        String?
  shippingMode       String?
  /// Signed PDF link Eshopbox returns; sellers print this to pack.
  labelUrl           String?
  routingCode        String?

  status ShipmentStatus @default(BOOKED)
  /// Raw Eshopbox status string (PICKED_UP, INTRANSIT, RTO…), kept verbatim
  /// so a status we don't map yet is still visible for support.
  courierStatus String?
  /// Full statusLogs array from the tracking API, as JSON.
  statusLogsJson       String?
  expectedDeliveryDate DateTime?

  bookedAt    DateTime  @default(now())
  pickedUpAt  DateTime?
  deliveredAt DateTime?
  cancelledAt DateTime?
  /// Last time we successfully reconciled against Eshopbox.
  syncedAt    DateTime?
  /// Populated when booking fails, so the seller sees why.
  lastError   String?

  updatedAt DateTime @updatedAt
}

enum ShipmentStatus {
  BOOKED
  PICKUP_PENDING
  PICKED_UP
  IN_TRANSIT
  OUT_FOR_DELIVERY
  DELIVERED
  FAILED_DELIVERY
  RTO
  RTO_DELIVERED
  CANCELLED
  EXCEPTION
}

enum PaymentMethod {
  ONLINE
  COD
}
