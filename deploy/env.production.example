# =============================================================================
# liveWAB — production environment for livewab.planwab.com
#
# Copy to `.env.production` in the project root ON THE VPS and fill in.
# NEVER commit the filled version. Lock it down after creating it:
#   chmod 600 .env.production
#
# docker-compose reads this file for BOTH runtime env and the NEXT_PUBLIC_*
# build args, so it must be present before `docker compose build`.
# =============================================================================

NODE_ENV=production

# Public origin. Used for canonical URLs, sitemap/robots, OpenGraph, and the
# links inside every transactional email. Must match the real domain exactly
# (no trailing slash) or Clerk redirects and email links will break.
NEXT_PUBLIC_APP_URL=https://livewab.planwab.com

# ---------------------------------------------------------------- database
# MongoDB Atlas. MUST be a replica set — reservations use transactions.
# Atlas Network Access must allow the VPS's public IPv4 address.
DATABASE_URL=

# ------------------------------------------------------------------- Clerk
# Use the PRODUCTION instance keys (pk_live_ / sk_live_), not test keys.
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
CLERK_WEBHOOK_SECRET=

NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_SIGN_IN_FALLBACK_REDIRECT_URL=/
NEXT_PUBLIC_CLERK_SIGN_UP_FALLBACK_REDIRECT_URL=/

# ---------------------------------------------------------------- payments
# Razorpay LIVE keys.
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=

# ----------------------------------------------------------------- LiveKit
# LIVEKIT_URL is the wss:// endpoint browsers connect to DIRECTLY — it does
# not pass through this VPS or Nginx.
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=
LIVEKIT_URL=wss://your-project.livekit.cloud

# ---------------------------------------------------------------- ImageKit
# Strongly recommended in production: without it, uploads fall back to local
# disk inside the container (a Docker volume), which doesn't scale or CDN.
NEXT_PUBLIC_IMAGEKIT_PUBLIC_KEY=
NEXT_PUBLIC_IMAGEKIT_URL_ENDPOINT=
IMAGEKIT_PRIVATE_KEY=

# ------------------------------------------------------------------- email
# SMTP. Verify after deploy with:
#   docker compose exec web node -e "…"   (or run npm run email:verify locally)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
EMAIL_FROM="liveWAB <orders@planwab.com>"
EMAIL_REPLY_TO=support@planwab.com

# ---------------------------------------------------------------- shipping
ESHOPBOX_CLIENT_ID=
ESHOPBOX_CLIENT_SECRET=
ESHOPBOX_REFRESH_TOKEN=
ESHOPBOX_CHANNEL_ID=
ESHOPBOX_ACCOUNT_SLUG=
ESHOPBOX_PICKUP_LOCATION_CODE=

# Eshopbox does not sign webhooks — this secret is what authenticates them.
# Generate with:
#   openssl rand -hex 32
ESHOPBOX_WEBHOOK_SECRET=
