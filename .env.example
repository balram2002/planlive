# ---------------------------------------------------------------------------
# Copy this file to .env.local and fill in real values. Do NOT commit .env.local.
# ---------------------------------------------------------------------------

# Public origin of the app — used for SEO (canonical URLs, sitemap, robots,
# OpenGraph). Set to your real domain in production, e.g. https://liveshop.in
NEXT_PUBLIC_APP_URL=http://localhost:3000

# MongoDB Atlas connection string. MUST be a replica set (Atlas is by default,
# even on the free tier) — multi-document transactions require it.
# Example: mongodb+srv://user:pass@cluster0.xxxxx.mongodb.net/liveshop?retryWrites=true&w=majority
DATABASE_URL=

# Clerk (https://dashboard.clerk.com -> API Keys)
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
# Created when you add a webhook endpoint in the Clerk dashboard (starts whsec_)
CLERK_WEBHOOK_SECRET=

# Clerk redirect URLs (defaults are fine for local dev)
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_SIGN_IN_FALLBACK_REDIRECT_URL=/
NEXT_PUBLIC_CLERK_SIGN_UP_FALLBACK_REDIRECT_URL=/

# ---- Not used until later milestones (placeholders for now) ----
# Razorpay (Milestone 6)
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=

# LiveKit (Milestone 3+)
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=
LIVEKIT_URL=

# ImageKit (imagekit.io dashboard -> Developer options). Used for profile
# pictures and stream thumbnails via direct client uploads. If unset, the app
# falls back to storing images on local disk (/public/uploads).
NEXT_PUBLIC_IMAGEKIT_PUBLIC_KEY=
NEXT_PUBLIC_IMAGEKIT_URL_ENDPOINT=
IMAGEKIT_PRIVATE_KEY=

# ---------------------------------------------------------------------------
# Email notifications (SMTP via Nodemailer)
# ---------------------------------------------------------------------------
# Order receipts, shipping updates, address/profile security notices, seller
# application decisions. If SMTP_HOST/USER/PASSWORD are unset the app logs
# each message and carries on — nothing breaks, no email is sent.
#
# Works with any SMTP provider. Examples:
#   Gmail / Workspace : smtp.gmail.com          port 587  (use an App Password)
#   Brevo             : smtp-relay.brevo.com    port 587
#   Amazon SES        : email-smtp.<region>.amazonaws.com  port 587
#   Zoho              : smtp.zoho.in            port 587
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=

# Envelope sender. For good deliverability this domain should have SPF, DKIM
# and DMARC records pointing at your SMTP provider.
EMAIL_FROM="liveWAB <orders@yourdomain.com>"

# Optional: where buyer replies land (defaults to EMAIL_FROM).
EMAIL_REPLY_TO=

# Check SMTP credentials and connectivity without sending an order:
#   npm run email:verify
#   npm run email:verify -- you@example.com   (sends a real test message)

# ---------------------------------------------------------------------------
# Shipping — Eshopbox (https://eshop.gitbook.io/eshopbox-developers)
# ---------------------------------------------------------------------------
# Ask your Eshopbox point of contact for a TESTING workspace first — shipments
# consume wallet credit, so validate the flow there before going live.
#
# Credentials live in your workspace under Apps -> Manual App.
ESHOPBOX_CLIENT_ID=
ESHOPBOX_CLIENT_SECRET=
ESHOPBOX_REFRESH_TOKEN=

# Sales channel these shipments belong to (Sales Channel tab).
ESHOPBOX_CHANNEL_ID=

# Your workspace subdomain, i.e. the "acme" in acme.myeshopbox.com.
# Required only to register webhooks.
ESHOPBOX_ACCOUNT_SLUG=

# Default warehouse the courier collects from. Sellers can override this
# per-shop on /shop-address.
ESHOPBOX_PICKUP_LOCATION_CODE=

# IMPORTANT — Eshopbox does NOT sign its webhook payloads. We register a
# secret header of our own instead, and the webhook route rejects anything
# without it. Generate a long random value, e.g.:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Then run: npm run eshopbox:register-webhook
ESHOPBOX_WEBHOOK_SECRET=
