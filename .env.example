# ---------------------------------------------------------------------------
# Copy this file to .env.local and fill in real values. Do NOT commit .env.local.
# ---------------------------------------------------------------------------

# Public origin of the app — used for SEO (canonical URLs, sitemap, robots,
# OpenGraph). Set to your real domain in production, e.g. https://liveshop.in
NEXT_PUBLIC_APP_URL=http://localhost:3000

# MongoDB Atlas connection string. MUST be a replica set (Atlas is by default,
# even on the free tier) — multi-document transactions require it.
# Example: mongodb+srv://user:pass@cluster0.xxxxx.mongodb.net/liveshop?retryWrites=true&w=majority
DATABASE_URL=

# Clerk (https://dashboard.clerk.com -> API Keys)
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
# Created when you add a webhook endpoint in the Clerk dashboard (starts whsec_)
CLERK_WEBHOOK_SECRET=

# Clerk redirect URLs (defaults are fine for local dev)
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_SIGN_IN_FALLBACK_REDIRECT_URL=/
NEXT_PUBLIC_CLERK_SIGN_UP_FALLBACK_REDIRECT_URL=/

# ---- Not used until later milestones (placeholders for now) ----
# Razorpay (Milestone 6)
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=

# LiveKit (Milestone 3+)
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=
LIVEKIT_URL=

# ImageKit (imagekit.io dashboard -> Developer options). Used for profile
# pictures and stream thumbnails via direct client uploads. If unset, the app
# falls back to storing images on local disk (/public/uploads).
NEXT_PUBLIC_IMAGEKIT_PUBLIC_KEY=
NEXT_PUBLIC_IMAGEKIT_URL_ENDPOINT=
IMAGEKIT_PRIVATE_KEY=

# ---------------------------------------------------------------------------
# Email notifications (Resend — https://resend.com/api-keys)
# ---------------------------------------------------------------------------
# Order receipts, shipping updates, address/profile security notices, seller
# application decisions. If RESEND_API_KEY is unset the app logs each message
# and carries on — nothing breaks, no email is sent.
RESEND_API_KEY=
# Must be a domain you've verified in Resend. The default onboarding sender
# only delivers to your own account address, so set this before going live.
EMAIL_FROM="liveWAB <orders@yourdomain.com>"

# ---------------------------------------------------------------------------
# WhatsApp notifications (Meta WhatsApp Cloud API)
# ---------------------------------------------------------------------------
# https://developers.facebook.com -> your app -> WhatsApp -> API Setup
# Leave unset to disable WhatsApp entirely (email still works).
WHATSAPP_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=

# IMPORTANT: Meta only allows business-initiated messages that use a
# PRE-APPROVED template. Create each template listed in
# src/lib/whatsapp/messages.ts (liveWAB_order_placed, liveWAB_order_shipped, …)
# in Business Manager -> Message Templates, with the same body placeholders.
# This must match the language your templates were approved in.
WHATSAPP_TEMPLATE_LOCALE=en

# Country code prepended to bare 10-digit numbers (91 = India).
WHATSAPP_DEFAULT_COUNTRY_CODE=91

# Dev only: send plain text instead of templates. This ONLY works for numbers
# that messaged your business in the last 24 hours. Never enable in production.
WHATSAPP_ALLOW_FREEFORM=
